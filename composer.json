{
    "name": "gubee-marketplace/php-sdk",
    "description": "Gubee SDK for PHP",
    "type": "library",
    "authors": [
        {
            "name": "Marcos 'Marcão' Aurelio",
            "email": "macosaures+git@gmail.com"
        },
        {
            "name": "Matheus Heiden",
            "email": "matheus.heiden@bis2bis.com.br"
        },
        {
            "name": "Gubee",
            "email": "contato@gubee.com.br"
        }
    ],
    "require": {
        "php": "^8.0",
        "php-di/php-di": "^6.4",
        "php-http/client-common": "^2.7",
        "php-http/discovery": "*",
        "php-http/multipart-stream-builder": "^1.3",
        "psr/container-implementation": "^1.0",
        "psr/http-client": "^1.0 | ^2.0",
        "psr/http-client-implementation": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^1.1|^2.0",	
        "symfony/http-client": ">=5.4"
    },
    "autoload": {
        "psr-4": {
            "Gubee\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gubee\\SDK\\Tests\\": "test/"
        }
    },
    "config": {
        "platform": {
            "php": "8.0.0"
        },
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "guzzlehttp/guzzle": "^7.8",
        "laminas/laminas-coding-standard": "^2.5",
        "league/openapi-psr7-validator": "^0.24",
        "monolog/monolog": "^2.9",
        "php-http/curl-client": "^2.3",
        "php-http/mock-client": "^1.6",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^9.6",
        "rector/rector": "^2.5"
    },
    "scripts": {
        "cs": [
            "@cs:check",
            "@cs:compat"
        ],
        "cs:check": "php -d error_reporting=8191 vendor/bin/phpcs",
        "cs:compat": "php -d error_reporting=8191 vendor/bin/phpcs --standard=PHPCompatibility --runtime-set testVersion 8.0- --runtime-set ignore_warnings_on_exit 1 src test",
        "cs:fix": "php -d error_reporting=8191 vendor/bin/phpcbf",
        "cs:stan": "php -d memory_limit=1G vendor/bin/phpstan analyse src test --level=6",
        "rector": "vendor/bin/rector process",
        "rector:dry-run": "vendor/bin/rector process --dry-run",
        "test": [
            "@test:unit",
            "@test:integration"
        ],
        "test:integration": "phpunit --testsuite=Integration",
        "test:unit": "phpunit --testsuite=Unit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-html=var/test/coverage",
        "test:coverage-badge": "XDEBUG_MODE=coverage phpunit --coverage-clover=var/test/coverage.xml && php .github/scripts/coverage-badge.php"
    }
}
